% --- Sidenotes
\ifthenelse{\equal\ST@type\ST@paper}{%
  \RequirePackage{sidenotes}
  \ifST@sidenotes
    \RequirePackage{mparhack}
    \renewcommand*{\marginfont}{\footnotesize}
    \newcommand{\note}[1]{%
      \sidenote{%
        \footnotesize
        \if@twoside        % Two sided layout
          \checkoddpage
          \ifoddpage
            \raggedright
          \else
            \raggedleft
          \fi
        \else              % One sided layout
          \raggedright
        \fi
        {#1}%
      }%
    }
  \else
    \newcommand{\note}[1]{\footnote{#1}}
  \fi
}

