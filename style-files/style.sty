  \DeclareTextFontCommand{\emph}{\bfseries}
\fi

% --- Split a longer document into different parts ---

\ifx\ST@type\ST@paper
  \def\part{\cleardoublepage\thispagestyle{empty}%
    \null\vfil \markboth{}{}\secdef\@part\@spart}

  \def\paperheader{\cleardoublepage\thispagestyle{empty}%
    \null\vfil \markboth{}{}\@spaper}
  \def\@spaper#1{
    \addtocontents{toc}{\protect\addvspace{0.25\baselineskip}}
    \addcontentsline{toc}{part}{\protect\noindent#1}%
    \addtocontents{toc}{\protect\addvspace{1\baselineskip}}
    \begin{center}
      \fontsize{\@xviipt}{15}\scshape#1
    \end{center}
  }

  % Code from `amsbooks'

  \def\@part[#1]#2{%
    \ifnum\c@secnumdepth >-2\relax \refstepcounter{part}%
      \addtocontents{toc}{\protect\addvspace{0.125\baselineskip}}
      \addcontentsline{toc}{section}{
        \textbf{\partname\ \thepart.
          \protect\enspace\protect\noindent#1}
      }
      \addtocontents{toc}{\protect\addvspace{0.125\baselineskip}}
      %
    \else
      \addcontentsline{toc}{section}{#1}
    \fi
    \begingroup\centering
    \ifnum\c@secnumdepth >-2\relax
      {\fontsize{\@xviipt}{15}\scshape
        \partname\ \thepart:} \vskip 15\p@
    \fi
    \fontsize{\@xviipt}{15}\scshape
    #1\vfil\vfil
    \endgroup
    \newpage
    \thispagestyle{empty}
  }
  \def\@spart#1{
    \addcontentsline{toc}{part}{\protect\noindent#1}%
    \begingroup\centering
    \fontsize{\@xviipt}{15}\scshape#1\vfil\vfil
    \endgroup
    \newpage
    \thispagestyle{empty}
  }

  % To remove certain items from the table of contents:
  \DeclareRobustCommand{\SkipTocEntry}[5]{}
\fi

% ------------------------------- Environments --------------------------------

\ifthenelse{\NOT\equal\ST@type\ST@org}{
  \theoremstyle{plain}
  \ifthenelse{\equal\ST@type\ST@paper \OR \equal\ST@type\ST@poster}{
    \newtheorem{theorem}{Theorem}
    \newtheorem{lemma}[theorem]{Lemma}
    \newtheorem{corollary}[theorem]{Corollary}
    \newtheorem{proposition}[theorem]{Proposition}
  }{}
  \newtheorem*{proposition*}{Proposition}
  \newtheorem*{conjecture}{Conjecture}

  \theoremstyle{definition}
  \ifthenelse{\equal\ST@type\ST@paper \OR \equal\ST@type\ST@poster}{
    \newtheorem*{theorem*}{Theorem}
    \newtheorem{definition}[theorem]{Definition}
    \newtheorem*{definition*}{Definition}
    \newtheorem{example}[theorem]{Example}
    \newtheorem{exercise}[theorem]{Exercise}
    \newtheorem{remark}[theorem]{Remark}
    \newtheorem{notation}[theorem]{Notation}
    \newtheorem{question}[theorem]{Question}
  }{}
  \newtheorem*{question*}{Question}
  \newtheorem*{remark*}{Remark}
  \newtheorem*{convention}{Convention}
}{}

