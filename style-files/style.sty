% ---- Autohandling
\ifx\ST@pkgOptions\empty\else

  \RequirePackage{trimspaces} % there is only so much I want to build by hand
  \def\ST@trim#1{\trim@spaces@noexp{#1}}

  % We will use etoolbox to pull this trick off.
  % Our input is a list of the form
  % foo = {a=1,b=2,c=3}, bar = e, ...
  % we split this at each outer "," using tje pkgparser defined below
  % then we have a new list(split by "=") of the form pkg = options.
  % we sanitise the pkg string(remove whitespaces) and then options to the package.
  % This is achieved by a counter logic.
  %First items are always pkgs and second items are always the options
  \newcounter{pkgoptcount}
  \newcommand*\temppkgname{}

  \def\parsepkg#1{%
    \setcounter{pkgoptcount}{0}
    \optionparser{\ST@process@option}{#1}
  }

  \def\ST@process@option#1{%
    \stepcounter{pkgoptcount}%
    \ifnum\value{pkgoptcount}=1\relax
      \edef\temppkgname{\ST@trim{#1}}%
    \else
      \PassOptionsToPackage{#1}{\temppkgname}%
      \setcounter{pkgoptcount}{0}%
      \renewcommand*\temppkgname{}%
    \fi
  }

  \def\ST@execute@pkgparser#1{\pkgparser{\parsepkg}{#1}}

  \DeclareListParser*{\optionparser}{=}
  \DeclareListParser*{\pkgparser}{,}

  \expandafter\ST@execute@pkgparser\expandafter{\ST@pkgOptions}
\fi

