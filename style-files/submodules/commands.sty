% --- Centres
\NewDocumentCommand{\buildCenter}{m o o m o}{
  \IfBooleanTF{#1}
  {\ensuremath{\mathsf{#2} \prescript{}{\mathsf{#3}}{(#4)}_{\mathsf{#5}}}\xspace}
  {\ensuremath{\mathsf{#2} \prescript{}{\mathsf{#3}}{(\cat{#4})}_{\mathsf{#5}}}\xspace}
}
\NewDocumentCommand{\cent}{s O{} m O{}}{\buildCenter{#1}[Z][#2]{#3}[#4]}
\newcommand*{\tcf}[2]{\buildCenter*[Z]{#1}[#2]}
\newcommand*{\tc}[1]{\tcf{#1}{T}}
\NewDocumentCommand{\ZCat}{s O{} m O{}}{\buildCenter{#1}[Z][#2]{#3}[#4]} % The center of a category
\NewDocumentCommand{\ACat}{s O{} m O{}}{\buildCenter{#1}[A][#2]{#3}[#4]} % Right twisted center
\NewDocumentCommand{\QCat}{s O{} m O{}}{\buildCenter{#1}[Q][#2]{#3}[#4]} % Left twisted center
\NewDocumentCommand{\SZCat}{s O{} m O{}}{\buildCenter{#1}[SZ][#2]{#3}[#4]} % The center of a category

