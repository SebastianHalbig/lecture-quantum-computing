% --- Duals

\def\ld{\@ifstar\@ldstar\@ldnostar}           % the left dual
\def\@ldstar#1{\ensuremath{{#1}^{\ast}}}
\def\@ldnostar#1{\ensuremath{\prescript{\vee}{}{\!#1}}}
\def\lld{\@ifstar\@lldstar\@lldnostar}        %the left double dual
\def\@lldstar#1{\ensuremath{{#1}^{\ast\ast}}}
\def\@lldnostar#1{\ensuremath{\prescript{\vee\vee}{}{\!#1}}}
\def\rd{\@ifstar\@rdstar\@rdnostar}           % the right dual
\def\@rdstar#1{\ensuremath{{#1}^{\ast}}}
\def\@rdnostar#1{\ensuremath{{#1}^{\vee}}}
\def\rrd{\@ifstar\@rrdstar\@rrdnostar}        %the right double dual
\def\@rrdstar#1{\ensuremath{{#1}^{\ast\ast}}}
\def\@rrdnostar#1{\ensuremath{{#1}^{\vee\vee}}}
\newcommand*{\ev}{\mathrm{ev}}          %   evaluation of the left  dual
\newcommand*{\evr}{\widetilde{\ev}}     %   evaluation of the right dual
\newcommand*{\coev}{\mathrm{coev}}      % coevaluation of the left  dual
\newcommand*{\coevr}{\widetilde{\coev}} % coevaluation of the right dual
\newcommand*{\ldual}[1]{(\ld{#1}, \ev_{#1}, \coev_{#1})}
\newcommand*{\rdual}[1]{(\rd{#1}, \evr_{#1}, \coevr_{#1})}

