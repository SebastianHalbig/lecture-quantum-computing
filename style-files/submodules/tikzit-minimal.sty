% --- Global options ---
\tikzset{baseline=(current bounding box.center)}
\tikzset{label distance=-0.15cm}
\tikzset{font=\scriptsize}
\tikzset{>=stealth}
\tikzset{
  dot diameter/.store in=\dot@diameter,
  dot diameter=2pt,
  dot spacing/.store in=\dot@spacing,
  dot spacing=10pt,
  dots/.style={
    line width=\dot@diameter,
    line cap=round,
    dash pattern=on 0pt off \dot@spacing
  }
}

% --- String diagrams ---

% --- Node styles ---
\tikzstyle{none} = [inner sep=3pt,outer sep=0pt]
\tikzstyle{morphism} = [rectangle, fill=white, draw=black, line width=1pt, font=\scriptsize]
\tikzset{
    vector/.style={
      isosceles triangle,
      isosceles triangle stretches,
      fill=white,
      draw=black,
      text width=0.25em,
      line width=1pt,
      font=\scriptsize,
    },
    dual/.style={
      shape border rotate=180,
      execute at begin node=\hspace{-1em}
    }
}
\tikzset{
    dagger-morph/.style={
        trapezium,
        trapezium left angle=90,
        trapezium right angle=75,
        shape border rotate=90, % Default: points left
        fill=white,
        draw=black,
        line width=1pt,
        font=\scriptsize
    },
    % Option 1: Transpose (flips the rotation)
    transpose/.style={
      shape border rotate=270,
    },
    adjoint/.style={
      shape border rotate=270,
      trapezium left angle=75,
      trapezium right angle=90,
    },
    % Option 2: Conjugate (thickens the "top" border)
    % Note: In a rotated trapezium, the 'top' is technically the 'trapezium left side'
    conjugate/.style={
      trapezium left angle=75,
      trapezium right angle=90,
    }
}
\tikzstyle{intersection-pt} = [fill=white, inner sep = 2.5pt]
\tikzstyle{fullblackdot}=[fill=black, draw, shape=circle, scale=0.7]
\tikzstyle{blackdot}=[fill=white, draw, shape=circle, scale=0.3]
\tikzstyle{PP}=[draw={rgb,255:red,102;green,41;blue,163}, shape=circle, fill={rgb,255:red,102;green,41;blue,163}, scale=0.5]

